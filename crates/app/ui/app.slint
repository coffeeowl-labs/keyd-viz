// keyd-viz UI — reproduces the original HTML cheatsheet's look natively.
// Data structs below mirror keydviz_core's Sheet/Board/KeyCap model; main.rs
// fills them in. Visual tokens (colors, sizes) match the original CSS.

import { ScrollView, LineEdit } from "std-widgets.slint";

export struct KeyCapData {
    // geometry in key units (absolute, from the top-left of the board)
    x: float,
    y: float,
    width: float,
    height: float,
    rotation: float,         // degrees clockwise about (rx, ry)
    rx: float,
    ry: float,
    key: string,             // keyd key name (for live keypress matching)
    phys: string,            // physical slot key name (config LHS) — what an edit binds
    label: string,
    emphasized: bool,        // large bold glyph (remap/override/momentary mod)
    ghost: string,           // faint top-right normal legend
    has_accent: bool,
    accent: brush,
    state: int,              // 0 normal, 1 dim, 2 hold
    pressed: bool,           // currently held down (live keypress glow)
    badge_left: string,
    badge_left_color: brush,
    has_badge_left: bool,
    badge_right: string,
    badge_right_color: brush,
    has_badge_right: bool,
}

export struct BoardData {
    is_base: bool,
    title: string,
    accent: brush,
    has_accent: bool,
    how: string,
    hint: string,
    keys: [KeyCapData],      // absolutely-positioned caps (not grouped into rows)
    extent_w: float,         // board width in key units
    extent_h: float,         // board height in key units
}

// One [ids] entry the config applies to; `matched` = the currently-plugged-in keyboard.
export struct IdTag {
    text: string,
    matched: bool,
}

export struct SheetData {
    name: string,
    path: string,
    profile: string,
    id_tags: [IdTag],       // the config's [ids] entries; matched = currently plugged in
    device: string,         // connected device that matched this config (empty if none)
    layout_id: string,      // curated-catalog layout id this sheet is drawn with
    boards: [BoardData],
}

// One pickable physical layout in the curated library (for the layout chip row).
export struct LayoutChoice {
    id: string,
    name: string,
}

// Maps a connected keyboard (vendor:product) to the index of the sheet it governs,
// so a live keypress can switch the view to whichever keyboard was last pressed.
export struct DeviceMatch {
    devid: string,
    sheet: int,
}

// One connected keyboard offered as a create-config target (design doc §5.5):
// keyboards no specific config governs (unclaimed or wildcard-only).
export struct CreateCandidateData {
    label: string,      // e.g. "PFU HHKB (04fe:0021)"
    id: string,         // the [ids] entry to seed: vendor:product (or "*" for the wildcard chip)
    suggested: string,  // suggested config file name (no .conf), already allow-list-safe
}

// ---- one key cap --------------------------------------------------------------
// Absolutely positioned on a 51px grid (46px cap + 5px gap), so any geometry —
// staggered, ortho, split, tall ISO-enter — renders from its (x, y, w, h) in key units.
component KeyCapView inherits Rectangle {
    in property <KeyCapData> data;
    // zoom multiplier (1.0 = native 51px pitch); threaded down from BoardView.
    in property <float> scale: 1.0;
    // edit mode: caps become clickable targets; `selected` highlights the one being
    // edited. Both off in the plain viewer, which stays pixel- and behavior-identical.
    in property <bool> editing: false;
    in property <bool> selected: false;
    callback clicked;

    // grid pitch = unit (46px) + gap (5px); a w-wide cap spans w cells minus one gap.
    x: data.x * 51px * scale;
    y: data.y * 51px * scale;
    width: (data.width * 46px + (data.width - 1) * 5px) * scale;
    height: (data.height * 46px + (data.height - 1) * 5px) * scale;
    border-radius: 7px * scale;
    // selection (edit mode) outranks the live glow; else pressed > dim/hold/normal.
    background: selected ? #3a2f14 : (data.pressed ? #26405f : (data.state == 1 ? #161b22 : #1b2129));
    border-width: (selected || data.pressed || data.state == 2) ? 2px : 1px;
    border-color: selected ? #f0b429 : (data.pressed ? #7cc4ff : (data.state == 2 ? data.accent : #2a3340));

    // Click-to-select, edit mode only. Decorative slots (no key name) aren't targets.
    // The TouchArea is disabled in the viewer so hover/click behavior there is unchanged;
    // scroll-to-zoom still works while editing because unhandled wheel events propagate
    // to the board's TouchArea.
    if root.editing && data.phys != "": TouchArea {
        mouse-cursor: pointer;
        clicked => {
            root.clicked();
        }
    }
    // raised "lip" approximating the CSS thick bottom border.
    drop-shadow-offset-y: 2px * scale;
    drop-shadow-blur: 0px;
    drop-shadow-color: #0b0e13;
    clip: true;

    // primary label, centered
    Text {
        width: 100%;
        height: 100%;
        text: data.label;
        color: data.pressed ? #ffffff : (data.state == 1 ? #4a525e : (data.has_accent ? data.accent : #cfd6df));
        font-size: (data.emphasized ? 16px : 15px) * scale;
        font-weight: data.emphasized ? 700 : 400;
        font-family: "JetBrains Mono";
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    // faint normal-legend, top-right
    if data.ghost != "": Text {
        x: parent.width - self.width - 4px * scale;
        y: 3px * scale;
        text: data.ghost;
        color: #5b6573;
        font-size: 9px * scale;
        font-family: "JetBrains Mono";
    }

    // bottom-left badge (hold target / HOLD)
    if data.has_badge_left: Rectangle {
        x: 4px * scale;
        y: parent.height - self.height - 2px * scale;
        width: bl.preferred-width + 6px * scale;
        height: bl.preferred-height + 2px * scale;
        background: data.badge_left_color;
        border-radius: 4px * scale;
        bl := Text {
            x: 3px * scale;
            y: 1px * scale;
            text: data.badge_left;
            color: #11151c;
            font-size: 9px * scale;
            font-weight: 700;
            font-family: "JetBrains Mono";
        }
    }

    // bottom-right badge (chord marker)
    if data.has_badge_right: Rectangle {
        x: parent.width - self.width - 4px * scale;
        y: parent.height - self.height - 2px * scale;
        width: br.preferred-width + 6px * scale;
        height: br.preferred-height + 2px * scale;
        background: data.badge_right_color;
        border-radius: 4px * scale;
        br := Text {
            x: 3px * scale;
            y: 1px * scale;
            text: data.badge_right;
            color: #11151c;
            font-size: 9px * scale;
            font-weight: 700;
            font-family: "JetBrains Mono";
        }
    }
}

// ---- one board (base layer or a single layer) ---------------------------------
component BoardView inherits VerticalLayout {
    in property <BoardData> data;
    // live layer state, threaded down from the window
    in property <string> active_layer;
    in property <bool> live;
    // edit mode, threaded down to the caps: which physical key is selected, and a
    // click callback back up to the window.
    in property <bool> editing: false;
    in property <string> selected_phys;
    // chord-building mode: instead of one selected key, up to two keys (the chord's
    // members) are highlighted as they're clicked.
    in property <bool> chord_mode: false;
    in property <string> chord_k1;
    in property <string> chord_k2;
    callback key_clicked(string);
    // zoom multiplier for the whole board (1.0 = native size). Scroll over the panel
    // adjusts it; the window auto-fits to the scaled extent.
    in-out property <float> zoom: 1.0;

    // is this the layer currently active on the keyboard? (base = nothing held)
    property <bool> is_active: data.is_base ? (active_layer == "") : (data.title == active_layer);
    property <bool> highlight: live && is_active;
    // accent used for the live highlight (green for the base/resting layer)
    property <brush> live_accent: data.is_base ? #3ddc84 : data.accent;

    // No per-board header: the active layer name is already in the window's LIVE pill, and
    // the green active border identifies the resting layer. Dropping it also means the board
    // never shifts when a layer activates (which was jarring while fast-typing).

    // keyboard panel, sized to the board extent and hugging its content. Caps are
    // absolutely positioned inside, so arbitrary geometry renders correctly.
    HorizontalLayout {
        alignment: start;
        Rectangle {
            background: #0c0f14;
            border-color: highlight ? live_accent : #1e2630;
            border-width: highlight ? 2px : 1px;
            border-radius: 12px;
            // pitch 51px; content = extent*51 - 5 (no trailing gap), + 10px padding each side
            width: (data.extent_w * 51px - 5px) * root.zoom + 20px;
            height: (data.extent_h * 51px - 5px) * root.zoom + 20px;
            // scroll anywhere over the board to zoom (wheel up = larger). The window
            // auto-fits, so this grows/shrinks the whole window with the board.
            TouchArea {
                scroll-event(e) => {
                    if (e.delta-y != 0px) {
                        root.zoom = Math.max(0.4, Math.min(2.4, root.zoom + (e.delta-y > 0px ? 0.1 : -0.1)));
                    }
                    return EventResult.accept;
                }
            }
            Rectangle {
                x: 10px;
                y: 10px;
                width: (data.extent_w * 51px - 5px) * root.zoom;
                height: (data.extent_h * 51px - 5px) * root.zoom;
                for key in data.keys: KeyCapView {
                    data: key;
                    scale: root.zoom;
                    editing: root.editing;
                    selected: root.editing && key.phys != ""
                        && (root.chord_mode
                            ? (key.phys == root.chord_k1 || key.phys == root.chord_k2)
                            : key.phys == root.selected_phys);
                    clicked => {
                        root.key_clicked(key.phys);
                    }
                }
            }
        }
    }
}

// ---- small pill button (zoom −/+, compact toggle) -----------------------------
component IconButton inherits Rectangle {
    in property <string> text;
    in property <image> icon;           // when set (with use_icon), drawn instead of text
    in property <bool> use_icon: false;
    in property <bool> wide: false;
    in property <bool> active: false;   // engaged/toggled state (e.g. pin on)
    callback clicked;
    width: root.use_icon ? 26px : (wide ? lbl.preferred-width + 18px : 26px);
    height: 24px;
    border-radius: 6px;
    background: active ? #16341f : (bta.has-hover ? #1b2129 : #161b22);
    border-width: 1px;
    border-color: active ? #3ddc84 : #2a3340;
    bta := TouchArea {
        clicked => {
            root.clicked();
        }
    }
    Image {
        visible: root.use_icon;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        width: 15px;
        height: 15px;
        source: root.icon;
        image-fit: contain;
        // SVGs are monochrome; tint to the theme (green when engaged).
        colorize: active ? #3ddc84 : (bta.has-hover ? #ffffff : #cfd6df);
    }
    lbl := Text {
        visible: !root.use_icon;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        text: root.text;
        color: active ? #3ddc84 : #cfd6df;
        font-size: 13px;
        font-weight: 700;
        font-family: "JetBrains Mono";
    }
}

// ---- zoom −/+ + percentage (click to reset) + compact toggle ------------------
component ViewControls inherits HorizontalLayout {
    in-out property <float> zoom;
    in-out property <bool> compact;
    in-out property <bool> pinned;
    spacing: 4px;
    alignment: end;

    IconButton {
        text: "\u{2212}";   // minus
        clicked => {
            root.zoom = Math.max(0.4, root.zoom - 0.1);
        }
    }
    // percentage readout; click to reset to 100%.
    Rectangle {
        width: pct.preferred-width + 12px;
        height: 24px;
        border-radius: 6px;
        background: pcta.has-hover ? #1b2129 : #161b22;
        border-width: 1px;
        border-color: #2a3340;
        pcta := TouchArea {
            clicked => {
                root.zoom = 1.0;
            }
        }
        pct := Text {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            text: "\{Math.round(root.zoom * 100)}%";
            color: #7d8694;
            font-size: 12px;
            font-weight: 700;
            font-family: "JetBrains Mono";
        }
    }
    IconButton {
        text: "+";
        clicked => {
            root.zoom = Math.min(2.4, root.zoom + 0.1);
        }
    }
    // Pin = keep the window above others (always-on-top). A persistent manual toggle;
    // compact mode also pins transiently (see MainWindow.on_top). Shown active (and the
    // un-slashed pin icon) while the window should be floating on top (manual pin OR
    // compact). Effective on X11/XWayland; on native Wayland keep-above is compositor-only
    // (see set_window_on_top in Rust).
    IconButton {
        use_icon: true;
        icon: (root.pinned || root.compact) ? @image-url("icons/pin.svg") : @image-url("icons/pin-off.svg");
        active: root.pinned || root.compact;
        clicked => {
            root.pinned = !root.pinned;
        }
    }
    // Compact toggle: the icon shows the action — shrink (compact) when expanded, grow
    // (expand) when compact.
    IconButton {
        use_icon: true;
        icon: root.compact ? @image-url("icons/expand.svg") : @image-url("icons/compact.svg");
        clicked => {
            root.compact = !root.compact;
        }
    }
}

// One editable section offered by the edit-mode layer chooser: `name` is the exact
// section base name in the file ("main" = base), `display` is what the chip shows.
export struct EditLayer {
    name: string,
    display: string,
}

// One chord listed under the selected key in the selection row: `chord` is the
// verbatim LHS spelling ("j+k") used to edit/delete it, `display` is the pretty
// "j + k" shown, `action` is the RHS ("esc" / "toggle(game)").
export struct ChordRow {
    chord: string,
    display: string,
    action: string,
}

// One step in the macro builder, in type order: `kind` ("key"|"text"|"chord"|"delay")
// is informational, `display` is the human label shown in the step's chip.
export struct MacroRow {
    kind: string,
    display: string,
}

// One row in the [global] options form: `name` is the keyd key, `label`/`hint` the
// human framing, `value` the current setting ("" = unset/default), `is_bool` renders
// a toggle, `known` distinguishes a documented option from an unrecognized line.
export struct GlobalRow {
    name: string,
    label: string,
    value: string,
    hint: string,
    is_bool: bool,
    known: bool,
}

// ---- apply countdown dialog ---------------------------------------------------
// A separate always-on-top window shown only during the dead-man countdown. Its
// reason to exist is the test field: keyd remaps at the device level, so typing
// here exercises the just-applied config without switching apps — and the timer
// sits right beside the box so you can see how long you have. KEEP / revert are
// mouse-driven (confirming must never require the keyboard under test). Closing
// this window reverts, like every non-KEEP exit.
export component ApplyDialog inherits Window {
    title: "keyd-viz — does your keyboard work?";
    background: #0c0f14;
    // Fixed width, height auto-fit to content (same auto-fit trick MainWindow
    // uses): the window must drive its own size — sizing a child doesn't size the
    // window, so without this it opens at Slint's default minimum width.
    width: 520px;
    height: dlg.preferred-height;
    // Focus the test field the moment the window appears, so the user can just
    // start typing to verify the remap.
    forward-focus: test_box;

    in property <int> seconds_left;
    in property <string> change_summary;   // the diff / what changed (mono)
    callback keep();
    callback revert();

    dlg := VerticalLayout {
        padding: 16px;
        spacing: 10px;

        Text {
            text: "Your change is live. Test it, then keep or revert.";
            color: #e6e6e6;
            font-size: 15px;
            font-weight: 700;
            wrap: word-wrap;
        }
        if root.change_summary != "": Rectangle {
            background: #11151c;
            border-color: #2a3340;
            border-width: 1px;
            border-radius: 8px;
            height: csum.preferred-height + 14px;
            csum := TextInput {
                x: 8px;
                y: 7px;
                width: parent.width - 16px;
                read-only: true;
                wrap: word-wrap;
                text: root.change_summary;
                color: #cfd6df;
                font-size: 12px;
                font-family: "JetBrains Mono";
            }
        }

        Text {
            text: "Type here to test your keyboard:";
            color: #7d8694;
            font-size: 12px;
            wrap: word-wrap;
        }
        // The throwaway test field — its content is never read; it exists purely
        // so the user can feel the remapped keys.
        test_box := LineEdit {
            height: 34px;
            font-size: 15px;
            placeholder-text: "press the keys you changed\u{2026}";
        }

        HorizontalLayout {
            spacing: 10px;
            Rectangle {
                width: tcd.preferred-width + 16px;
                height: 28px;
                border-radius: 6px;
                background: #122117;
                border-width: 1px;
                border-color: #3ddc84;
                tcd := Text {
                    x: 8px;
                    y: (parent.height - self.height) / 2;
                    text: "reverting in \{root.seconds_left}s";
                    color: #3ddc84;
                    font-size: 13px;
                    font-weight: 700;
                }
            }
            Rectangle { horizontal-stretch: 1; }
            IconButton {
                wide: true;
                text: "revert";
                clicked => {
                    root.revert();
                }
            }
            IconButton {
                wide: true;
                text: "KEEP \u{2014} it works";
                active: true;
                clicked => {
                    root.keep();
                }
            }
        }

        Text {
            text: "\u{26a0} keyboard dead? Backspace+Escape+Enter restarts keyd";
            color: #f0b429;
            font-size: 12px;
            font-weight: 700;
            wrap: word-wrap;
        }
        Text {
            text: "anything but KEEP reverts \u{2014} timeout, revert, or closing this window";
            color: #7d8694;
            font-size: 11px;
            wrap: word-wrap;
        }
    }
}

// ---- main window --------------------------------------------------------------
export component MainWindow inherits Window {
    title: "keyd-viz";
    background: #11151c;
    // Auto-fit the window to its content. `body`'s preferred size is intrinsic (driven by
    // the board extent), so the window resizes itself when you pick a different layout or
    // switch keyboards — no manual resizing to match a layout.
    width: body.preferred-width;
    height: body.preferred-height;
    default-font-family: "JetBrains Mono";

    // live layer state (set from Rust via the keyd listen thread)
    in property <bool> live_connected;   // keyd listen (layer) stream connected
    in property <bool> keys_connected;   // keyd monitor (keypress) stream connected
    in property <string> active_layer;
    // The single active keyboard and the one board to show for it — a single morphing
    // board that the keyd listen stream swaps as the active layer changes (Rust resolves
    // the active layer to a real board, falling back to base).
    in property <SheetData> active_sheet;
    in property <BoardData> active_board;
    // Load-time `[ids]` collision warnings: two configs claiming the same device id
    // (or both the wildcard) at the same rank — keyd resolves it by file order. One
    // per line; "" = clean. Shown in the viewer (outside edit mode); §5.5.
    in property <string> load_warnings: "";

    // Live state Rust mutates on the UI thread; kept here so successive listen/monitor
    // callbacks share it without crossing a thread boundary (Slint models aren't Send).
    in-out property <[string]> active_stack;   // raw keyd layer stack (most recent last)
    in-out property <[string]> pressed_keys;   // keyd key names currently held down
    in-out property <int> active_index;        // index into `sheets` currently shown
    // Storage for the follow-the-last-pressed-keyboard logic (not directly rendered).
    in property <[SheetData]> sheets;
    in property <[DeviceMatch]> device_map;
    // The curated layouts offered in the picker (empty hides it, e.g. QMK-imported).
    in property <[LayoutChoice]> layouts;
    // The user picked a physical layout for the active keyboard (id of the choice).
    callback pick_layout(string);
    // The user picked which detected keyboard to show (index into `sheets`).
    callback pick_keyboard(int);

    // view state: zoom level for the board and a compact mode that hides all chrome
    // (header, ids, layout picker) to leave a minimal, pinnable keyboard-only window.
    in-out property <float> zoom: 1.0;
    in-out property <bool> compact: false;
    // Keep-window-above-others. `pinned` is the user's persistent toggle (the pin button);
    // compact mode pins transiently. `on_top` is the effective state Rust applies to the
    // window. NB: this only takes effect on X11/XWayland — native Wayland has no client-side
    // keep-above protocol, so there it's a no-op (use the compositor's keep-above instead).
    in-out property <bool> pinned: false;
    property <bool> on_top: pinned || compact;
    changed on_top => { root.apply_on_top(self.on_top); }
    // Implemented in Rust: set the underlying window's always-on-top level.
    callback apply_on_top(bool);

    // ---- edit mode (Phase 6 E1: draft-then-install) ----
    // Editing is an explicit, opt-in mode; in the plain viewer everything below is
    // inert and nothing edit-related is rendered.
    in-out property <bool> edit_mode: false;
    in property <[EditLayer]> edit_layers;   // sections offered while editing
    in property <string> edit_layer;         // exact section name being edited ("main" = base)
    in property <string> selected_phys;      // physical key picked on the board ("" = none)
    in property <string> edit_current;       // the selection's current binding (display only)
    in-out property <string> edit_value;     // the value field (Rust seeds it on selection)
    in property <bool> edit_dirty;           // session has unsaved changes
    in property <string> edit_banner;        // affected-keyboards line / view-only reason
    in property <string> edit_warnings;      // orphan-layer warnings (one per line); "" = clean
    in property <bool> capture_armed;        // next live keypress becomes the value
    in property <string> draft_info;         // after save: draft path + diff + install steps
    // Guard against silently dropping unsaved edits: leaving edit mode (done / switch
    // keyboard) while dirty raises a confirm bar instead of discarding immediately.
    in-out property <bool> discard_prompt: false;
    in-out property <int> pending_kbd: -1;   // keyboard to switch to after confirming (-1 = just leave)
    // Common actions offered as one-click chips (the categorized palette grows in E2).
    property <[string]> palette: ["esc", "tab", "backspace", "delete", "enter",
        "leftcontrol", "leftalt", "leftmeta", "leftshift", "noop"];
    callback toggle_edit();
    callback select_key(string);
    callback pick_edit_layer(string);
    // ---- layer create / delete (E2) ----
    in-out property <bool> new_layer_open: false;   // the inline "new layer" name field is showing
    in-out property <string> new_layer_name: "";    // name being typed for a new layer
    in-out property <string> delete_prompt: "";      // layer pending delete-confirm ("" = none)
    in property <string> delete_detail: "";          // confirm-bar detail (count + dangling refs)
    callback create_layer(string);          // create a new empty layer and select it
    callback delete_layer(string);          // request delete of a layer → opens the confirm bar
    callback confirm_delete_layer();        // delete the layer named in delete_prompt
    callback cancel_delete_layer();         // dismiss the delete confirm
    // ---- layer rename (E2) ----
    in-out property <string> rename_target: "";  // layer pending rename ("" = field closed)
    in-out property <string> rename_name: "";    // new name being typed
    in property <bool> can_rename: false;        // is the selected layer renameable (not main/composite)
    callback rename_layer(string, string);  // (old base, new name) → rename + rewrite refs
    callback apply_binding(string);          // typed / palette / captured value for the selection
    callback make_transparent();             // clear the selection's binding → falls through to base
    callback arm_capture();
    // A selected key's binding is remap XOR tap/hold — one binding line, never both.
    // `key_mode` ("simple" | "taphold") picks which editor shows; Rust seeds it from
    // the current binding on select. (Chords are a SEPARATE construct — see board_mode.)
    in-out property <string> key_mode: "simple";
    callback set_key_mode(string);
    // ---- tap/hold (dual-function) editor: VIA's Mod-Tap / Layer-Tap ----
    in property <[string]> hold_layers;      // the config's layers offered as "when held" (no main)
    // keyd's fixed modifier set — the other "when held" choices (Mod-Tap).
    property <[string]> hold_mods: ["control", "shift", "alt", "meta", "altgr"];
    in property <bool> selected_is_tap_hold; // the selection is already a tap/hold binding
    in-out property <string> th_hold;        // chosen hold target (a layer or modifier)
    in-out property <string> th_tap;         // tap action (defaults to the physical key)
    in-out property <bool> th_hold_only;     // momentary: hold only, no tap action
    in-out property <string> th_feel;        // tap-vs-hold "feel": "fast" | "safe"
    callback apply_tap_hold();               // compose th_hold/th_tap into the binding
    // ---- macro editor: an ordered list of typed steps (keyd macro(...)/macro2(...)) ----
    // The draft steps live in Rust (the real tokens); `macro_rows` is the rebuilt view.
    // Pending sub-form fields stage one not-yet-added step; "set macro" commits the list.
    in property <bool> selected_is_macro;          // the selection is already a macro binding
    in property <[MacroRow]> macro_rows;           // the draft steps, in order
    in-out property <string> macro_text_input;     // staged "type text" step
    in-out property <string> macro_delay_input;    // staged delay (ms) step
    in-out property <bool> macro_chord_c;          // staged chord: Control held
    in-out property <bool> macro_chord_m;          // staged chord: Meta held
    in-out property <bool> macro_chord_a;          // staged chord: Alt held
    in-out property <bool> macro_chord_s;          // staged chord: Shift held
    in-out property <bool> macro_chord_g;          // staged chord: AltGr held
    in-out property <string> macro_chord_key;      // staged chord: the key
    in-out property <bool> macro_repeat_on;        // wrap as macro2 (repeat while held)
    in-out property <string> macro_repeat_timeout; // macro2 first-repeat delay (ms)
    in-out property <string> macro_repeat_count;   // macro2 between-repeat delay (ms)
    callback macro_add_text();                     // append a "type text" step
    callback macro_add_delay();                    // append a pause step
    callback macro_add_chord();                    // append a chord step (mods + key)
    callback macro_remove(int);                    // remove the step at this index
    callback macro_move(int, int);                 // move the step (index, -1 up / +1 down)
    callback apply_macro();                         // serialize the draft → set the binding
    // ---- searchable key picker (E2): browse keyd's full key vocabulary ----
    // A shared overlay; `picker_target` routes the pick to the binding or the tap field.
    // Fill-only: picking sets the field, it does not apply — the user still hits "set".
    in-out property <bool> picker_open: false;
    in-out property <string> picker_target: "";   // "binding" | "tap" | "chord_action" | "macro_token" | "macro_chord_key"
    in-out property <string> picker_query: "";
    in property <[string]> picker_results;         // ranked slice (Rust holds the full list)
    in property <int> picker_truncated: 0;         // matches dropped past the cap (0 = all shown)
    in property <string> picker_source;            // "keyd list-keys (N)" | "built-in list"
    callback filter_keys(string);
    callback open_picker(string);   // arg = target ("binding" | "tap" | "chord_action")
    callback pick_key(string);
    // ---- chords (E2): two keys pressed together → one action. A SEPARATE construct
    // from a key's own binding (keyd disambiguates by timing). Chord-building is a
    // *mode of the main board* (`board_mode == "chord"`): the two keys are picked by
    // clicking them on the board, not from a dialog. `board_mode` ("single" | "chord")
    // is the board's interaction mode — "single" edits one key's binding, "chord"
    // turns the board into a two-key picker. The two are mutually exclusive, so a key's
    // tap/hold editor and chord-building never overlap. Chords are [main]-only, so the
    // mode toggle is offered only when the main layer is selected. `chord_rows` lists
    // every chord in [main]; `chord_key1`/`chord_key2` are the two clicked keys.
    in-out property <string> board_mode: "single";
    callback set_board_mode(string);  // switch the board between "single" and "chord"
    in property <[ChordRow]> chord_rows;
    in-out property <string> chord_key1: "";    // first key of the builder ("" = none clicked)
    in-out property <string> chord_key2: "";    // second key of the builder
    in-out property <string> chord_action: "";  // action for the builder
    callback add_chord();             // commit chord_key1 + chord_key2 → chord_action
    callback edit_chord(string);      // arg = chord LHS → seed the builder from it
    callback remove_chord(string);    // arg = chord LHS → delete it
    // ---- [global] daemon options (E2): a typed form for keyd's documented globals.
    // `editing_global` swaps the per-key editors for the options form; a layer chip
    // returns to key editing. `global_rows` is rebuilt by Rust after each change.
    in property <bool> editing_global: false;
    in property <[GlobalRow]> global_rows;
    callback edit_global();              // enter the global-options form
    callback set_global(string, string); // (name, value) — "" value clears to default
    callback clear_global(string);       // remove an option → keyd default
    callback save_draft();
    callback confirm_discard();   // discard the unsaved session and proceed (leave / switch)
    callback cancel_discard();    // dismiss the prompt, stay in the session

    // ---- one-click apply (Phase 6 E2: pkexec + dead-man's switch) ----
    // Gated by Rust at session open: the file must be `/etc/keyd/<name>.conf`
    // (apply-tool name allow-list) AND pkexec + the packaged tool must exist.
    in property <bool> apply_available: false;
    in property <string> apply_hint;         // why one-click is absent ("" = no hint row)
    // idle | confirm | auth | countdown | kept | reverted | revert-failed | failed.
    // Only KEEP persists a change; every other exit from `countdown` reverts.
    in property <string> apply_state: "idle";
    in property <string> apply_info;         // findings / staleness / diff / outcome detail
    property <bool> apply_in_flight: root.apply_state == "confirm"
        || root.apply_state == "auth" || root.apply_state == "countdown";
    callback start_apply();    // pre-flight; → confirm (sensitive) or straight to auth
    callback confirm_apply();  // explicit command()/macro() acknowledgement
    callback cancel_apply();   // leave confirm / cancel auth / dismiss a terminal state
    // KEEP / revert during the countdown live on ApplyDialog, not here.

    // ---- delete config (Phase 6 E2: remove a whole config file, §5.5) ----
    // A destructive, confirm-gated counterpart to create-config. For a persisted
    // config it runs the privileged delete (same auth → countdown → KEEP/revert as
    // apply); for a never-saved one Rust just drops the phantom board.
    in-out property <bool> delete_config_prompt: false;  // the confirm bar is showing
    callback delete_config();  // confirmed: delete this config (or drop the phantom)

    // ---- create config (Phase 6 E2: a starter config for an unconfigured keyboard, §5.5) ----
    in-out property <bool> create_open: false;          // the create panel is showing (only outside edit mode)
    in property <[CreateCandidateData]> create_candidates;  // connected keyboards no specific config governs
    in-out property <string> create_selected_id: "";   // chosen [ids] entry (a vendor:product or "*")
    in-out property <string> create_name: "";           // config file name being typed (no .conf)
    in-out property <string> create_error: "";          // bad name / filename-collision reason ("" = ok)
    in property <string> create_governed: "";           // "already configured" explainer ("" = none)
    callback begin_create();                 // open the panel: populate candidates + sensible defaults
    callback create_config(string, string);  // (ids entry, name) → create the starter + enter edit mode

    // Compact mode hides the create panel *and* its cancel button (both gated `!compact`),
    // so close the panel when entering compact — otherwise the user is stuck with invisible
    // create state until they un-compact. Compact is a transient overlay; a half-started new
    // config shouldn't survive into it.
    changed compact => {
        if (root.compact && root.create_open) {
            root.create_open = false;
            root.create_selected_id = "";
            root.create_name = "";
            root.create_error = "";
        }
    }

    ScrollView {
        body := VerticalLayout {
            padding: root.compact ? 8px : 22px;
            spacing: root.compact ? 8px : 12px;
            alignment: start;

            // top row: keyboard chooser on the left, zoom/compact controls on the right.
            // The live-status pill lives on line 2 (with the path) so its width changing as
            // the layer name changes doesn't combine with the chooser and resize the window.
            if !root.compact: HorizontalLayout {
                alignment: space-between;
                spacing: 12px;

                // keyboard chooser — the primary navigation. With 2+ detected keyboards
                // these are clickable chips (keyd merges them into one virtual device, so
                // the view can't auto-follow the last-pressed one); with one, just its name.
                if root.sheets.length > 1: HorizontalLayout {
                    spacing: 6px;
                    alignment: start;
                    for sheet[idx] in root.sheets: Rectangle {
                        property <bool> sel: idx == root.active_index;
                        width: kb.preferred-width + 20px;
                        height: kb.preferred-height + 12px;
                        border-radius: 7px;
                        background: sel ? #3ddc84 : (kta.has-hover ? #1b2129 : #161b22);
                        border-width: 1px;
                        border-color: sel ? #3ddc84 : #2a3340;
                        kta := TouchArea {
                            clicked => {
                                root.pick_keyboard(idx);
                            }
                        }
                        kb := Text {
                            x: 10px;
                            y: 6px;
                            text: sheet.device != "" ? sheet.device : sheet.name;
                            color: sel ? #11151c : #cfd6df;
                            font-size: 13px;
                            font-weight: sel ? 700 : 400;
                            font-family: "JetBrains Mono";
                        }
                    }
                }
                if root.sheets.length <= 1: Text {
                    text: root.active_sheet.device != "" ? root.active_sheet.device : root.active_sheet.name;
                    color: #e6e6e6;
                    font-size: 18px;
                    font-weight: 700;
                    vertical-alignment: center;
                }

                HorizontalLayout {
                    spacing: 4px;
                    alignment: end;
                    // New-config entry (Phase 6 E2, §5.5). Hidden while editing (finish or
                    // cancel the current edit first) and while the create panel is already open.
                    if !root.edit_mode && !root.create_open: IconButton {
                        wide: true;
                        text: "+ config";
                        clicked => {
                            root.begin_create();
                        }
                    }
                    // Edit-mode toggle (Phase 6 E1). The viewer is the default; "done"
                    // leaves edit mode (the session's unsaved preview is discarded).
                    IconButton {
                        wide: true;
                        text: root.edit_mode ? "done" : "edit";
                        active: root.edit_mode;
                        clicked => {
                            root.toggle_edit();
                        }
                    }
                    ViewControls {
                        zoom <=> root.zoom;
                        compact <=> root.compact;
                        pinned <=> root.pinned;
                    }
                }
            }

            // compact mode: just a slim controls bar (so you can still zoom / un-compact)
            // above the bare board.
            if root.compact: HorizontalLayout {
                alignment: end;
                ViewControls {
                    zoom <=> root.zoom;
                    compact <=> root.compact;
                    pinned <=> root.pinned;
                }
            }

            // line 2: source config file + the [ids] it applies to on the left, the
            // live-status pill on the right. The id matching the currently-plugged-in
            // keyboard is highlighted green.
            if !root.compact: HorizontalLayout {
                alignment: space-between;
                spacing: 12px;

                // left: config path + [ids].
                HorizontalLayout {
                    spacing: 8px;
                    alignment: start;
                    Text {
                        text: root.active_sheet.path;
                        color: #7d8694;
                        font-size: 12px;
                        vertical-alignment: center;
                    }
                    for tag in root.active_sheet.id_tags: Rectangle {
                        width: idt.preferred-width + 12px;
                        height: idt.preferred-height + 5px;
                        border-radius: 5px;
                        background: tag.matched ? #133a2a : #161b22;
                        border-width: 1px;
                        border-color: tag.matched ? #3ddc84 : #2a3340;
                        idt := Text {
                            x: 6px;
                            y: 2px;
                            text: tag.text;
                            color: tag.matched ? #3ddc84 : #7d8694;
                            font-size: 11px;
                            font-weight: tag.matched ? 700 : 400;
                            font-family: "JetBrains Mono";
                        }
                    }
                }

                // right: live-status pill. Three states: full live (layers), keys-only
                // (monitor works but the keyd-group layer socket doesn't), and off.
                Rectangle {
                    property <bool> any_live: root.live_connected || root.keys_connected;
                    width: pill.preferred-width + 18px;
                    height: pill.preferred-height + 8px;
                    border-radius: 8px;
                    background: any_live ? #122017 : #161b22;
                    border-width: 1px;
                    border-color: any_live ? #3ddc84 : #2a3340;
                    pill := Text {
                        x: 9px;
                        y: 4px;
                        text: root.live_connected
                            ? "\u{25cf} LIVE  \u{b7}  \{root.active_layer == "" ? "base" : root.active_layer}"
                            : (root.keys_connected
                                ? "\u{25cf} LIVE keys  \u{b7}  layers need the 'keyd' group"
                                : "\u{25cb} live view off  \u{b7}  add yourself to the 'keyd' group");
                        color: any_live ? #3ddc84 : #7d8694;
                        font-size: 12px;
                        font-weight: 700;
                    }
                }
            }

            // layout picker: a row of chips to morph the board onto a different physical
            // layout. Hidden when there are no choices (QMK-imported board) or in compact mode.
            if root.layouts.length > 0 && !root.compact: HorizontalLayout {
                spacing: 6px;
                alignment: start;
                Text {
                    text: "layout";
                    color: #7d8694;
                    font-size: 12px;
                    vertical-alignment: center;
                }
                for choice in root.layouts: Rectangle {
                    property <bool> sel: choice.id == root.active_sheet.layout_id;
                    width: chip.preferred-width + 18px;
                    height: chip.preferred-height + 8px;
                    border-radius: 7px;
                    background: sel ? #1f6feb : (ta.has-hover ? #1b2129 : #161b22);
                    border-width: 1px;
                    border-color: sel ? #1f6feb : #2a3340;
                    ta := TouchArea {
                        clicked => {
                            root.pick_layout(choice.id);
                        }
                    }
                    chip := Text {
                        x: 9px;
                        y: 4px;
                        text: choice.name;
                        color: sel ? #ffffff : #cfd6df;
                        font-size: 12px;
                        font-weight: sel ? 700 : 400;
                        font-family: "JetBrains Mono";
                    }
                }
            }

            // why edit mode refused to engage (round-trip gate / keyd-rejects / QMK) —
            // shown in the viewer, since the edit panel never opened to show it.
            if !root.edit_mode && !root.compact && root.edit_banner != "": Text {
                text: "\u{26a0} \{root.edit_banner}";
                color: #f0b429;
                font-size: 12px;
            }

            // load-time [ids] collision warnings: two configs claim the same device id
            // (or both the wildcard) at the same rank — keyd picks one by file order.
            // Viewer-only (the user should see it without entering edit mode); §5.5.
            if !root.edit_mode && !root.compact && root.load_warnings != "": Rectangle {
                background: #241d10;
                border-color: #f0b429;
                border-width: 1px;
                border-radius: 8px;
                height: lwarn.preferred-height + 14px;
                lwarn := Text {
                    x: 9px;
                    y: 7px;
                    width: parent.width - 18px;
                    text: root.load_warnings;
                    color: #f0b429;
                    font-size: 12px;
                    font-family: "JetBrains Mono";
                    wrap: word-wrap;
                }
            }

            // ---- create-config panel (Phase 6 E2, §5.5) -------------------------------
            // Outside edit mode: pick the keyboard a new config should govern (a connected
            // one, or all keyboards via the wildcard), name it, and start editing the
            // starter. Creating enters edit mode on the new config; the rest of the
            // edit/preview/draft/apply flow is unchanged from here.
            if root.create_open && !root.edit_mode && !root.compact: Rectangle {
                background: #0c0f14;
                border-color: #3ddc84;
                border-width: 1px;
                border-radius: 12px;
                height: createbody.preferred-height;
                createbody := VerticalLayout {
                    padding: 12px;
                    spacing: 8px;

                    Text {
                        text: "New config";
                        color: #e6e6e6;
                        font-size: 15px;
                        font-weight: 700;
                    }
                    Text {
                        text: "Which keyboard should this config govern?";
                        color: #7d8694;
                        font-size: 12px;
                    }

                    // candidate keyboards (connected, not already governed by a specific
                    // config) + a wildcard option. Picking one seeds the id and a suggested
                    // name; the name stays editable.
                    HorizontalLayout {
                        spacing: 6px;
                        alignment: start;
                        for cand in root.create_candidates: Rectangle {
                            property <bool> sel: cand.id == root.create_selected_id;
                            width: cc.preferred-width + 18px;
                            height: cc.preferred-height + 8px;
                            border-radius: 7px;
                            background: sel ? #16341f : (cca.has-hover ? #1b2129 : #161b22);
                            border-width: 1px;
                            border-color: sel ? #3ddc84 : #2a3340;
                            cca := TouchArea {
                                clicked => {
                                    // Only seed the suggested name when switching to a
                                    // *different* keyboard — re-clicking the selected chip
                                    // mustn't clobber a name the user has since typed.
                                    if (root.create_selected_id != cand.id) {
                                        root.create_name = cand.suggested;
                                    }
                                    root.create_selected_id = cand.id;
                                    root.create_error = "";
                                }
                            }
                            cc := Text {
                                x: 9px;
                                y: 4px;
                                text: cand.label;
                                color: sel ? #3ddc84 : #cfd6df;
                                font-size: 12px;
                                font-weight: sel ? 700 : 400;
                                font-family: "JetBrains Mono";
                            }
                        }
                        // Wildcard: applies to every keyboard not claimed by another config.
                        Rectangle {
                            property <bool> sel: root.create_selected_id == "*";
                            width: wc.preferred-width + 18px;
                            height: wc.preferred-height + 8px;
                            border-radius: 7px;
                            background: sel ? #16341f : (wca.has-hover ? #1b2129 : #161b22);
                            border-width: 1px;
                            border-color: sel ? #3ddc84 : #2a3340;
                            wca := TouchArea {
                                clicked => {
                                    if (root.create_selected_id != "*") {
                                        root.create_name = "default";
                                    }
                                    root.create_selected_id = "*";
                                    root.create_error = "";
                                }
                            }
                            wc := Text {
                                x: 9px;
                                y: 4px;
                                text: "All keyboards (*)";
                                color: sel ? #3ddc84 : #cfd6df;
                                font-size: 12px;
                                font-weight: sel ? 700 : 400;
                                font-family: "JetBrains Mono";
                            }
                        }
                    }

                    // Explainer: connected keyboards already governed by a specific config
                    // are intentionally absent from the chips above — you edit those, not
                    // create a colliding second config (§5.5). Name them so it's not a mystery.
                    if root.create_governed != "": Text {
                        text: root.create_governed;
                        color: #7d8694;
                        font-size: 11px;
                        wrap: word-wrap;
                    }

                    // name + create/cancel
                    HorizontalLayout {
                        spacing: 8px;
                        alignment: start;
                        Text {
                            text: "name:";
                            color: #7d8694;
                            font-size: 12px;
                            vertical-alignment: center;
                        }
                        LineEdit {
                            width: 200px;
                            height: 28px;
                            font-size: 13px;
                            placeholder-text: "config name (e.g. hhkb)";
                            text <=> root.create_name;
                            // No `init => self.focus()` — same ScrollView recursion guard as
                            // the new-layer / rename fields. The user clicks to focus.
                            accepted(t) => {
                                root.create_config(root.create_selected_id, t);
                            }
                        }
                        Text {
                            text: ".conf";
                            color: #7d8694;
                            font-size: 13px;
                            font-family: "JetBrains Mono";
                            vertical-alignment: center;
                        }
                        IconButton {
                            wide: true;
                            text: "create";
                            active: root.create_name != "" && root.create_selected_id != "";
                            clicked => {
                                root.create_config(root.create_selected_id, root.create_name);
                            }
                        }
                        IconButton {
                            wide: true;
                            text: "cancel";
                            clicked => {
                                root.create_open = false;
                                root.create_selected_id = "";
                                root.create_name = "";
                                root.create_error = "";
                            }
                        }
                    }

                    if root.create_error != "": Text {
                        text: "\u{26a0} \{root.create_error}";
                        color: #e5534b;
                        font-size: 12px;
                    }
                }
            }

            // ---- edit panel (edit mode only; the viewer never renders any of this) ----
            if root.edit_mode && !root.compact: Rectangle {
                background: #0c0f14;
                border-color: #f0b429;
                border-width: 1px;
                border-radius: 12px;
                height: editbody.preferred-height;
                editbody := VerticalLayout {
                    padding: 12px;
                    spacing: 8px;

                    // discard guard: shown when leaving edit mode with unsaved changes,
                    // so edits are never dropped silently (save draft first, or confirm).
                    if root.discard_prompt: Rectangle {
                        height: dbar.preferred-height + 12px;
                        border-radius: 8px;
                        background: #2a1d1d;
                        border-width: 1px;
                        border-color: #e5534b;
                        dbar := HorizontalLayout {
                            padding-left: 10px;
                            padding-right: 10px;
                            spacing: 10px;
                            Text {
                                text: "\u{26a0} Unsaved changes will be lost.";
                                color: #ff8b82;
                                font-size: 12px;
                                font-weight: 700;
                                vertical-alignment: center;
                                horizontal-stretch: 1;
                            }
                            IconButton {
                                wide: true;
                                text: "discard";
                                clicked => {
                                    root.confirm_discard();
                                }
                            }
                            IconButton {
                                wide: true;
                                text: "keep editing";
                                active: true;
                                clicked => {
                                    root.cancel_discard();
                                }
                            }
                        }
                    }

                    // banner: EDIT pill + which keyboards this file governs + dirty marker
                    HorizontalLayout {
                        spacing: 8px;
                        alignment: start;
                        Rectangle {
                            width: edp.preferred-width + 12px;
                            height: edp.preferred-height + 5px;
                            border-radius: 5px;
                            background: #f0b429;
                            edp := Text {
                                x: 6px;
                                y: 2px;
                                text: "EDIT";
                                color: #11151c;
                                font-size: 11px;
                                font-weight: 700;
                            }
                        }
                        Text {
                            text: root.edit_banner;
                            color: #7d8694;
                            font-size: 12px;
                            vertical-alignment: center;
                        }
                        if root.edit_dirty: Text {
                            text: "\u{25cf} unsaved";
                            color: #f0b429;
                            font-size: 12px;
                            font-weight: 700;
                            vertical-alignment: center;
                        }
                    }

                    // orphan-layer warnings: bindings that activate a layer this config
                    // never defines (keyd would reject the file). Config-level, so shown
                    // regardless of selection; recomputed after every edit.
                    if root.edit_warnings != "": Rectangle {
                        background: #241d10;
                        border-color: #f0b429;
                        border-width: 1px;
                        border-radius: 8px;
                        height: owarn.preferred-height + 14px;
                        owarn := Text {
                            x: 9px;
                            y: 7px;
                            width: parent.width - 18px;
                            text: root.edit_warnings;
                            color: #f0b429;
                            font-size: 12px;
                            font-family: "JetBrains Mono";
                            wrap: word-wrap;
                        }
                    }

                    // delete-layer confirm: deleting a layer removes the section and all
                    // its bindings (and may leave dangling references) — so it's gated by
                    // an explicit confirm bar, like the discard guard.
                    if root.delete_prompt != "": Rectangle {
                        height: delbar.preferred-height + 12px;
                        border-radius: 8px;
                        background: #2a1d1d;
                        border-width: 1px;
                        border-color: #e5534b;
                        delbar := HorizontalLayout {
                            padding-left: 10px;
                            padding-right: 10px;
                            spacing: 10px;
                            Text {
                                text: root.delete_detail;
                                color: #ff8b82;
                                font-size: 12px;
                                font-weight: 700;
                                vertical-alignment: center;
                                horizontal-stretch: 1;
                                wrap: word-wrap;
                            }
                            IconButton {
                                wide: true;
                                text: "delete";
                                clicked => {
                                    root.confirm_delete_layer();
                                }
                            }
                            IconButton {
                                wide: true;
                                text: "keep";
                                active: true;
                                clicked => {
                                    root.cancel_delete_layer();
                                }
                            }
                        }
                    }

                    // ⚙ global lives on its own row above the layers: it edits keyd's
                    // daemon-wide options, which belong to no layer (and no key). Selecting
                    // it swaps in the options form and hides the board.
                    HorizontalLayout {
                        spacing: 6px;
                        alignment: start;
                        Rectangle {
                            property <bool> sel: root.editing_global;
                            width: gbl.preferred-width + 16px;
                            height: gbl.preferred-height + 8px;
                            border-radius: 7px;
                            background: sel ? #f0b429 : (gblta.has-hover ? #1b2129 : #161b22);
                            border-width: 1px;
                            border-color: sel ? #f0b429 : #2a3340;
                            gblta := TouchArea {
                                clicked => {
                                    root.edit_global();
                                }
                            }
                            gbl := Text {
                                x: 8px;
                                y: 4px;
                                // when open, show a ✕ so it's clear the chip also closes
                                // the form (the form hides the board, so it's the way out).
                                text: sel ? "\u{2699} global \u{2715}" : "\u{2699} global";
                                color: sel ? #11151c : #cfd6df;
                                font-size: 12px;
                                font-weight: sel ? 700 : 400;
                                font-family: "JetBrains Mono";
                            }
                        }
                    }

                    // layer chooser: which layer section the key edits land in, plus the
                    // create / rename / delete layer ops. (Global is its own row above;
                    // chords are a mode of the main board — see the mode toggle below — not
                    // a section.) Picking a layer freezes the board to it.
                    HorizontalLayout {
                        spacing: 6px;
                        alignment: start;
                        Text {
                            text: "layer";
                            color: #7d8694;
                            font-size: 12px;
                            vertical-alignment: center;
                        }
                        for lay in root.edit_layers: Rectangle {
                            property <bool> sel: lay.name == root.edit_layer && !root.editing_global;
                            width: elt.preferred-width + 16px;
                            height: elt.preferred-height + 8px;
                            border-radius: 7px;
                            background: sel ? #f0b429 : (elta.has-hover ? #1b2129 : #161b22);
                            border-width: 1px;
                            border-color: sel ? #f0b429 : #2a3340;
                            elta := TouchArea {
                                clicked => {
                                    root.pick_edit_layer(lay.name);
                                }
                            }
                            elt := Text {
                                x: 8px;
                                y: 4px;
                                text: lay.display;
                                color: sel ? #11151c : #cfd6df;
                                font-size: 12px;
                                font-weight: sel ? 700 : 400;
                                font-family: "JetBrains Mono";
                            }
                        }
                        // + layer: open the inline name field below the chooser. Hidden
                        // while a delete confirm or rename field is pending (resolve first),
                        // or while editing globals (no layer context then).
                        if !root.editing_global && !root.new_layer_open && root.delete_prompt == "" && root.rename_target == "": Rectangle {
                            width: addl.preferred-width + 16px;
                            height: addl.preferred-height + 8px;
                            border-radius: 7px;
                            background: addlta.has-hover ? #16341f : #131a14;
                            border-width: 1px;
                            border-color: #2f5d3a;
                            addlta := TouchArea {
                                clicked => {
                                    root.new_layer_name = "";
                                    root.new_layer_open = true;
                                }
                            }
                            addl := Text {
                                x: 8px;
                                y: 4px;
                                text: "+ layer";
                                color: #3ddc84;
                                font-size: 12px;
                                font-weight: 700;
                                font-family: "JetBrains Mono";
                            }
                        }
                        // rename the selected layer (opens the inline name field, rewriting
                        // every reference on commit). Offered only for a real named layer —
                        // `can_rename` excludes the `main` base and composites. Hidden while
                        // another layer dialog is up.
                        if root.can_rename && !root.editing_global && !root.new_layer_open && root.delete_prompt == "" && root.rename_target == "": Rectangle {
                            width: renl.preferred-width + 16px;
                            height: renl.preferred-height + 8px;
                            border-radius: 7px;
                            background: renlta.has-hover ? #16283a : #121a22;
                            border-width: 1px;
                            border-color: #2f4d5d;
                            renlta := TouchArea {
                                clicked => {
                                    // Pre-fill with the current name; the user edits it.
                                    root.rename_name = root.edit_layer;
                                    root.rename_target = root.edit_layer;
                                }
                            }
                            renl := Text {
                                x: 8px;
                                y: 4px;
                                text: "\u{270e} rename";
                                color: #6cc5ff;
                                font-size: 12px;
                                font-weight: 700;
                                font-family: "JetBrains Mono";
                            }
                        }
                        // delete the selected layer (confirm-gated). Hidden once the
                        // confirm bar (or rename field) is up, so it can't re-target. The
                        // base board ("main") can't be deleted — it's keyd's root layer,
                        // not a user layer (mirrors the rename chip's main exclusion).
                        if root.edit_layer != "" && root.edit_layer != "main" && !root.editing_global && !root.new_layer_open && root.delete_prompt == "" && root.rename_target == "": Rectangle {
                            width: dell.preferred-width + 16px;
                            height: dell.preferred-height + 8px;
                            border-radius: 7px;
                            background: dellta.has-hover ? #2a1717 : #1a1212;
                            border-width: 1px;
                            border-color: #5d2f2f;
                            dellta := TouchArea {
                                clicked => {
                                    root.delete_layer(root.edit_layer);
                                }
                            }
                            dell := Text {
                                x: 8px;
                                y: 4px;
                                text: "\u{2715} delete";
                                color: #ff8b82;
                                font-size: 12px;
                                font-weight: 700;
                                font-family: "JetBrains Mono";
                            }
                        }
                    }

                    // new-layer name field: shown after "+ layer"; create adds an empty
                    // [name] section and selects it (then bind keys / point a layer() at it).
                    if root.new_layer_open: HorizontalLayout {
                        spacing: 8px;
                        alignment: start;
                        Text {
                            text: "new layer:";
                            color: #7d8694;
                            font-size: 12px;
                            vertical-alignment: center;
                        }
                        LineEdit {
                            width: 180px;
                            height: 28px;
                            font-size: 13px;
                            placeholder-text: "name (e.g. symbols)";
                            text <=> root.new_layer_name;
                            // NOTE: no `init => self.focus()` here — unlike the key
                            // picker (which floats outside the ScrollView), this field
                            // lives inside the body ScrollView, and self-focusing makes
                            // the ScrollView scroll-to-visible mid-layout → Slint
                            // "Recursion detected" panic. The user clicks to focus.
                            accepted(t) => {
                                root.create_layer(t);
                            }
                        }
                        IconButton {
                            wide: true;
                            text: "create";
                            active: root.new_layer_name != "";
                            clicked => {
                                root.create_layer(root.new_layer_name);
                            }
                        }
                        IconButton {
                            wide: true;
                            text: "cancel";
                            clicked => {
                                root.new_layer_open = false;
                                root.new_layer_name = "";
                            }
                        }
                    }

                    // rename-layer name field: shown after "✎ rename"; renaming rewrites the
                    // section header(s) and every binding that points at the layer, so nothing
                    // orphans. The target is whichever layer was selected when "rename" was hit.
                    if root.rename_target != "": HorizontalLayout {
                        spacing: 8px;
                        alignment: start;
                        Text {
                            text: "rename [" + root.rename_target + "] to:";
                            color: #7d8694;
                            font-size: 12px;
                            vertical-alignment: center;
                        }
                        LineEdit {
                            width: 180px;
                            height: 28px;
                            font-size: 13px;
                            placeholder-text: "new name";
                            text <=> root.rename_name;
                            // No `init => self.focus()` — same ScrollView recursion guard as
                            // the new-layer field above. The user clicks to focus.
                            accepted(t) => {
                                root.rename_layer(root.rename_target, t);
                            }
                        }
                        IconButton {
                            wide: true;
                            text: "rename";
                            active: root.rename_name != "" && root.rename_name != root.rename_target;
                            clicked => {
                                root.rename_layer(root.rename_target, root.rename_name);
                            }
                        }
                        IconButton {
                            wide: true;
                            text: "cancel";
                            clicked => {
                                root.rename_target = "";
                                root.rename_name = "";
                            }
                        }
                    }

                    // board interaction mode. "single key" edits one key's binding (click
                    // a key → remap or tap/hold below); "chord" turns the board into a
                    // two-key picker (click two keys → one action), scoped to the selected
                    // layer (keyd scopes a chord to the layer it's declared in). Exactly
                    // one is active, so a key's tap/hold and chord-building never overlap.
                    // Hidden while editing globals (no board then).
                    if !root.editing_global && root.edit_layer != "": HorizontalLayout {
                        spacing: 8px;
                        alignment: start;
                        Text {
                            text: "mode:";
                            color: #7d8694;
                            font-size: 12px;
                            vertical-alignment: center;
                        }
                        IconButton {
                            wide: true;
                            text: "single key";
                            active: root.board_mode != "chord";
                            clicked => {
                                root.set_board_mode("single");
                            }
                        }
                        IconButton {
                            wide: true;
                            text: "\u{2328} chord";
                            active: root.board_mode == "chord";
                            clicked => {
                                root.set_board_mode("chord");
                            }
                        }
                        Text {
                            text: root.board_mode == "chord"
                                ? "click two keys on the board"
                                : "click a key on the board";
                            color: #5a6673;
                            font-size: 11px;
                            vertical-alignment: center;
                        }
                    }

                    // [global] daemon options form: a typed editor for keyd's documented
                    // globals (timeouts, layer_indicator, default_layout, …). Shown when the
                    // ⚙ global chip is selected; the per-key editors below are hidden then.
                    if root.editing_global: VerticalLayout {
                        spacing: 7px;
                        Text {
                            text: "global options \u{2014} keyd daemon settings (blank a field to reset to default)";
                            color: #7d8694;
                            font-size: 11px;
                        }
                        for g in root.global_rows: HorizontalLayout {
                            spacing: 8px;
                            alignment: start;
                            Text {
                                text: g.label;
                                color: g.value != "" ? #cfd6df : #7d8694;
                                font-size: 12px;
                                width: 200px;
                                vertical-alignment: center;
                            }
                            // boolean option → on/off toggle (keyd writes 1/0).
                            if g.is_bool: IconButton {
                                wide: true;
                                text: g.value == "1" ? "on" : "off";
                                active: g.value == "1";
                                clicked => {
                                    root.set_global(g.name, g.value == "1" ? "" : "1");
                                }
                            }
                            // everything else → a text field; Enter commits, blank clears.
                            if !g.is_bool: LineEdit {
                                width: 120px;
                                height: 26px;
                                font-size: 12px;
                                placeholder-text: "default";
                                text: g.value;
                                accepted(t) => {
                                    root.set_global(g.name, t);
                                }
                            }
                            Text {
                                text: g.known ? g.hint : "(unrecognized \u{2014} kept as-is)";
                                color: #5a6673;
                                font-size: 11px;
                                vertical-alignment: center;
                            }
                            // clear an explicitly-set option (dimmed when already at default).
                            if g.value != "": IconButton {
                                wide: true;
                                text: "\u{2715}";
                                clicked => {
                                    root.clear_global(g.name);
                                }
                            }
                        }
                    }

                    // selection: the picked key, its current binding, and a behavior
                    // toggle (remap XOR tap/hold — one binding line, never both). Chords
                    // are a separate construct (the ⌨ chords panel), so nothing stacks here.
                    if !root.editing_global && root.board_mode != "chord" && root.selected_phys == "": Text {
                        text: "click a key on the board to edit its binding";
                        color: #7d8694;
                        font-size: 12px;
                    }
                    // header row: key chip + current binding + simple/tap-hold toggle
                    if !root.editing_global && root.board_mode != "chord" && root.selected_phys != "": HorizontalLayout {
                        spacing: 8px;
                        alignment: start;
                        Rectangle {
                            width: selk.preferred-width + 14px;
                            height: 28px;
                            border-radius: 6px;
                            background: #3a2f14;
                            border-width: 1px;
                            border-color: #f0b429;
                            selk := Text {
                                x: 7px;
                                y: (parent.height - self.height) / 2;
                                text: root.selected_phys;
                                color: #f0b429;
                                font-size: 13px;
                                font-weight: 700;
                                font-family: "JetBrains Mono";
                            }
                        }
                        Text {
                            // unbound: keyd stops remapping the key. On a sublayer it
                            // inherits the base layer; on base there is nothing below, so
                            // keyd just forwards the key's real (hardware) code — not a
                            // firmware fallback, keyd simply ceases to intercept.
                            text: root.edit_current != ""
                                ? "= \{root.edit_current}"
                                : (root.edit_layer == "main" || root.edit_layer == "")
                                    ? "no remap \u{2014} sends the real key"
                                    : "inherits base";
                            color: root.edit_current == "" ? #7d8694 : #cfd6df;
                            font-size: 13px;
                            font-family: "JetBrains Mono";
                            vertical-alignment: center;
                        }
                        Text {
                            text: "behavior:";
                            color: #7d8694;
                            font-size: 12px;
                            vertical-alignment: center;
                        }
                        IconButton {
                            wide: true;
                            text: "simple";
                            active: root.key_mode == "simple";
                            clicked => {
                                root.set_key_mode("simple");
                            }
                        }
                        IconButton {
                            wide: true;
                            text: "tap / hold";
                            active: root.key_mode == "taphold";
                            clicked => {
                                root.set_key_mode("taphold");
                            }
                        }
                        IconButton {
                            wide: true;
                            text: "macro";
                            active: root.key_mode == "macro";
                            clicked => {
                                root.set_key_mode("macro");
                            }
                        }
                    }
                    // simple remap editor — shown in "simple" mode (a plain key→key,
                    // disable, or unbind). Tap/hold lives in its own panel below.
                    if !root.editing_global && root.board_mode != "chord" && root.selected_phys != "" && root.key_mode == "simple": HorizontalLayout {
                        spacing: 8px;
                        alignment: start;
                        Text {
                            text: "\u{2192}";
                            color: #7d8694;
                            font-size: 13px;
                            vertical-alignment: center;
                        }
                        LineEdit {
                            width: 220px;
                            height: 28px;
                            font-size: 13px;
                            placeholder-text: "new binding (e.g. esc)";
                            text <=> root.edit_value;
                            accepted(t) => {
                                root.apply_binding(t);
                            }
                        }
                        IconButton {
                            wide: true;
                            text: "set";
                            clicked => {
                                root.apply_binding(root.edit_value);
                            }
                        }
                        // browse keyd's full key vocabulary (fills the field, doesn't apply).
                        IconButton {
                            wide: true;
                            text: "pick\u{2026}";
                            clicked => {
                                root.open_picker("binding");
                            }
                        }
                        // "unbind": clear the binding so keyd stops remapping the key —
                        // on a sublayer it inherits the base layer, on base it sends the
                        // real key. Distinct from "noop" (which disables the key). Dimmed
                        // when the key is already unbound — nothing to clear. (We avoid
                        // QMK's "▽ transparent": keyd has no firmware layer to fall through
                        // to, so the word would mislead — see the marker comment below.)
                        Rectangle {
                            width: trp.preferred-width + 14px;
                            height: 24px;
                            border-radius: 6px;
                            property <bool> already: root.edit_current == "";
                            background: already ? #12161c : (trpta.has-hover ? #16242a : #11191d);
                            border-width: 1px;
                            border-color: already ? #2a3340 : #2f5d63;
                            trpta := TouchArea {
                                enabled: !already;
                                mouse-cursor: already ? default : pointer;
                                clicked => {
                                    root.make_transparent();
                                }
                            }
                            trp := Text {
                                x: 7px;
                                y: (parent.height - self.height) / 2;
                                text: "unbind";
                                color: already ? #4a525e : #6fc3cf;
                                font-size: 12px;
                                font-weight: 700;
                                font-family: "JetBrains Mono";
                            }
                        }
                        // press-to-capture: the next live keypress becomes the value.
                        // Needs the keypress stream; greyed-out hint when it's absent.
                        if root.keys_connected: IconButton {
                            wide: true;
                            text: root.capture_armed ? "press a key\u{2026}" : "capture";
                            active: root.capture_armed;
                            clicked => {
                                root.arm_capture();
                            }
                        }
                        if !root.keys_connected: Text {
                            text: "(no live key stream to capture from)";
                            color: #4a525e;
                            font-size: 11px;
                            vertical-alignment: center;
                        }
                    }

                    // chord editor (board "chord" mode) — two keys struck together emit one
                    // action. The two keys are picked by clicking them on the main board
                    // above; this panel shows the running build + every existing [main] chord.
                    if !root.editing_global && root.board_mode == "chord": VerticalLayout {
                        spacing: 6px;
                        Text {
                            text: "chords (" + root.edit_layer + ") \u{2014} click two keys on the board, then set an action";
                            color: #7d8694;
                            font-size: 11px;
                        }
                        for c in root.chord_rows: HorizontalLayout {
                            spacing: 8px;
                            alignment: start;
                            Rectangle {
                                width: crow.preferred-width + 14px;
                                height: 26px;
                                border-radius: 6px;
                                background: #11191d;
                                border-width: 1px;
                                border-color: #2a3340;
                                crow := Text {
                                    x: 7px;
                                    y: (parent.height - self.height) / 2;
                                    text: "\{c.display} \u{2192} \{c.action}";
                                    color: #cfd6df;
                                    font-size: 12px;
                                    font-family: "JetBrains Mono";
                                }
                            }
                            IconButton {
                                wide: true;
                                text: "\u{270e} edit";
                                clicked => {
                                    root.edit_chord(c.chord);
                                }
                            }
                            IconButton {
                                wide: true;
                                text: "\u{2715} remove";
                                clicked => {
                                    root.remove_chord(c.chord);
                                }
                            }
                        }
                        // build row: the two keys are filled by clicking the board above
                        // (the picked keys also light up there); set an action and add.
                        HorizontalLayout {
                            spacing: 8px;
                            alignment: start;
                            Rectangle {
                                width: ck1.preferred-width + 14px;
                                height: 28px;
                                border-radius: 6px;
                                background: root.chord_key1 != "" ? #3a2f14 : #11191d;
                                border-width: 1px;
                                border-color: root.chord_key1 != "" ? #f0b429 : #2a3340;
                                ck1 := Text {
                                    x: 7px;
                                    y: (parent.height - self.height) / 2;
                                    text: root.chord_key1 != "" ? root.chord_key1 : "click key 1\u{2026}";
                                    color: root.chord_key1 != "" ? #f0b429 : #7d8694;
                                    font-size: 13px;
                                    font-weight: root.chord_key1 != "" ? 700 : 400;
                                    font-family: "JetBrains Mono";
                                }
                            }
                            Text {
                                text: "+";
                                color: #7d8694;
                                font-size: 14px;
                                vertical-alignment: center;
                            }
                            Rectangle {
                                width: ck2.preferred-width + 14px;
                                height: 28px;
                                border-radius: 6px;
                                background: root.chord_key2 != "" ? #3a2f14 : #11191d;
                                border-width: 1px;
                                border-color: root.chord_key2 != "" ? #f0b429 : #2a3340;
                                ck2 := Text {
                                    x: 7px;
                                    y: (parent.height - self.height) / 2;
                                    text: root.chord_key2 != "" ? root.chord_key2 : "click key 2\u{2026}";
                                    color: root.chord_key2 != "" ? #f0b429 : #7d8694;
                                    font-size: 13px;
                                    font-weight: root.chord_key2 != "" ? 700 : 400;
                                    font-family: "JetBrains Mono";
                                }
                            }
                            // clear the two picked keys to start the chord over.
                            if root.chord_key1 != "" || root.chord_key2 != "": IconButton {
                                wide: true;
                                text: "\u{2715} clear";
                                clicked => {
                                    root.chord_key1 = "";
                                    root.chord_key2 = "";
                                }
                            }
                            Text {
                                text: "\u{2192}";
                                color: #7d8694;
                                font-size: 13px;
                                vertical-alignment: center;
                            }
                            LineEdit {
                                width: 160px;
                                height: 28px;
                                font-size: 13px;
                                placeholder-text: "action (e.g. esc)";
                                text <=> root.chord_action;
                                accepted(t) => {
                                    root.add_chord();
                                }
                            }
                            IconButton {
                                wide: true;
                                text: "pick\u{2026}";
                                clicked => {
                                    root.open_picker("chord_action");
                                }
                            }
                            IconButton {
                                wide: true;
                                text: "add";
                                clicked => {
                                    root.add_chord();
                                }
                            }
                        }
                    }

                    // tap / hold (dual-function) key — VIA's Mod-Tap / Layer-Tap.
                    // "When held" picks a layer or modifier; "when tapped" is a key
                    // (or none, for a momentary hold). keyd's per-key timeouts aren't
                    // exposed; an existing key's timings are preserved on the Rust side.
                    if !root.editing_global && root.board_mode != "chord" && root.selected_phys != "" && root.key_mode == "taphold": Rectangle {
                        background: #11151c;
                        border-radius: 8px;
                        border-width: 1px;
                        border-color: #2a3340;
                        thp := VerticalLayout {
                            padding: 9px;
                            spacing: 7px;
                            HorizontalLayout {
                                spacing: 8px;
                                Text {
                                    text: "tap / hold (dual-function)";
                                    color: #8a93a0;
                                    font-size: 12px;
                                    font-weight: 700;
                                    vertical-alignment: center;
                                }
                                if root.selected_is_tap_hold: Text {
                                    text: "\u{2022} editing existing \u{2014} any timings preserved";
                                    color: #5a6673;
                                    font-size: 11px;
                                    vertical-alignment: center;
                                }
                            }
                            // when held: a layer or a modifier (one selectable chip).
                            HorizontalLayout {
                                spacing: 6px;
                                alignment: start;
                                Text {
                                    text: "hold:";
                                    color: #cfd6df;
                                    font-size: 12px;
                                    font-family: "JetBrains Mono";
                                    vertical-alignment: center;
                                }
                                for lay in root.hold_layers: IconButton {
                                    wide: true;
                                    text: lay;
                                    active: root.th_hold == lay;
                                    clicked => {
                                        root.th_hold = lay;
                                    }
                                }
                                for m in root.hold_mods: IconButton {
                                    wide: true;
                                    text: m;
                                    active: root.th_hold == m;
                                    clicked => {
                                        root.th_hold = m;
                                    }
                                }
                            }
                            // when tapped: a key (disabled for a momentary hold).
                            HorizontalLayout {
                                spacing: 8px;
                                alignment: start;
                                Text {
                                    text: "tap:";
                                    color: #cfd6df;
                                    font-size: 12px;
                                    font-family: "JetBrains Mono";
                                    vertical-alignment: center;
                                }
                                LineEdit {
                                    width: 160px;
                                    height: 28px;
                                    font-size: 13px;
                                    enabled: !root.th_hold_only;
                                    // Blank tap falls back to the key itself; use the
                                    // "hold only" toggle for a true no-tap (momentary) key.
                                    placeholder-text: root.th_hold_only
                                        ? "(hold only)"
                                        : "taps " + root.selected_phys;
                                    text <=> root.th_tap;
                                }
                                if !root.th_hold_only: IconButton {
                                    wide: true;
                                    text: "pick\u{2026}";
                                    clicked => {
                                        root.open_picker("tap");
                                    }
                                }
                                IconButton {
                                    wide: true;
                                    text: "hold only";
                                    active: root.th_hold_only;
                                    clicked => {
                                        root.th_hold_only = !root.th_hold_only;
                                    }
                                }
                            }
                            // feel: how the key disambiguates tap vs hold. Labels say
                            // what they do (no keyd jargon, no ms); hovering reveals the
                            // one-line detail on its own fixed-height line (blank at
                            // rest → no layout jitter). Only meaningful when there's a tap.
                            if !root.th_hold_only: VerticalLayout {
                                spacing: 4px;
                                HorizontalLayout {
                                    spacing: 8px;
                                    alignment: start;
                                    Text {
                                        text: "feel:";
                                        color: #cfd6df;
                                        font-size: 12px;
                                        font-family: "JetBrains Mono";
                                        vertical-alignment: center;
                                    }
                                    Rectangle {
                                        property <bool> sel: root.th_feel == "fast";
                                        width: tf.preferred-width + 16px;
                                        height: tf.preferred-height + 8px;
                                        border-radius: 6px;
                                        background: sel ? #16341f : (fastta.has-hover ? #1b2129 : #161b22);
                                        border-width: 1px;
                                        border-color: sel ? #3ddc84 : #2a3340;
                                        fastta := TouchArea {
                                            clicked => {
                                                root.th_feel = "fast";
                                            }
                                        }
                                        tf := Text {
                                            x: 8px;
                                            y: 4px;
                                            text: "fast typing";
                                            color: parent.sel ? #3ddc84 : #cfd6df;
                                            font-size: 12px;
                                            font-family: "JetBrains Mono";
                                        }
                                    }
                                    Rectangle {
                                        property <bool> sel: root.th_feel == "safe";
                                        width: ts.preferred-width + 16px;
                                        height: ts.preferred-height + 8px;
                                        border-radius: 6px;
                                        background: sel ? #16341f : (safeta.has-hover ? #1b2129 : #161b22);
                                        border-width: 1px;
                                        border-color: sel ? #3ddc84 : #2a3340;
                                        safeta := TouchArea {
                                            clicked => {
                                                root.th_feel = "safe";
                                            }
                                        }
                                        ts := Text {
                                            x: 8px;
                                            y: 4px;
                                            text: "avoid misfires";
                                            color: parent.sel ? #3ddc84 : #cfd6df;
                                            font-size: 12px;
                                            font-family: "JetBrains Mono";
                                        }
                                    }
                                }
                                Text {
                                    // Fixed height so the row never reflows; empty until a
                                    // chip is hovered, or a static nudge for an unnamed form.
                                    height: 15px;
                                    text: fastta.has-hover
                                        ? "engages on overlap, no pause — best for fast typing"
                                        : safeta.has-hover
                                            ? "ignores quick taps — won’t trigger by accident"
                                            : (root.selected_is_tap_hold && root.th_feel == "")
                                                ? "custom form kept as-is — pick a feel to change it"
                                                : "";
                                    color: #5a6673;
                                    font-size: 11px;
                                    vertical-alignment: center;
                                    overflow: elide;
                                }
                            }
                            HorizontalLayout {
                                alignment: start;
                                IconButton {
                                    wide: true;
                                    text: "set tap/hold";
                                    active: root.th_hold != "";
                                    clicked => {
                                        if (root.th_hold != "") {
                                            root.apply_tap_hold();
                                        }
                                    }
                                }
                            }
                        }
                    }

                    // macro editor — shown in "macro" mode: an ordered list of steps
                    // (keys, typed text, chords, pauses) that keyd plays back. Optional
                    // "repeat while held" wraps it as macro2.
                    if !root.editing_global && root.board_mode != "chord" && root.selected_phys != "" && root.key_mode == "macro": Rectangle {
                        background: #11151c;
                        border-radius: 8px;
                        border-width: 1px;
                        border-color: #2a3340;
                        VerticalLayout {
                            padding: 9px;
                            spacing: 7px;
                            HorizontalLayout {
                                spacing: 8px;
                                Text {
                                    text: "macro (types a sequence of steps)";
                                    color: #8a93a0;
                                    font-size: 12px;
                                    font-weight: 700;
                                    vertical-alignment: center;
                                }
                                if root.selected_is_macro: Text {
                                    text: "\u{2022} editing existing";
                                    color: #5a6673;
                                    font-size: 11px;
                                    vertical-alignment: center;
                                }
                            }
                            // the ordered steps, each with reorder + remove controls.
                            if root.macro_rows.length == 0: Text {
                                text: "no steps yet \u{2014} add a key, text, chord, or pause below";
                                color: #5a6673;
                                font-size: 11px;
                            }
                            for m[idx] in root.macro_rows: HorizontalLayout {
                                spacing: 6px;
                                alignment: start;
                                Rectangle {
                                    width: mrow.preferred-width + 16px;
                                    height: 26px;
                                    border-radius: 6px;
                                    background: #11191d;
                                    border-width: 1px;
                                    border-color: #2a3340;
                                    mrow := Text {
                                        x: 8px;
                                        y: (parent.height - self.height) / 2;
                                        text: m.display;
                                        color: #cfd6df;
                                        font-size: 12px;
                                        font-family: "JetBrains Mono";
                                    }
                                }
                                IconButton {
                                    text: "\u{2191}";
                                    clicked => {
                                        root.macro_move(idx, -1);
                                    }
                                }
                                IconButton {
                                    text: "\u{2193}";
                                    clicked => {
                                        root.macro_move(idx, 1);
                                    }
                                }
                                IconButton {
                                    text: "\u{2715}";
                                    clicked => {
                                        root.macro_remove(idx);
                                    }
                                }
                            }
                            // add a key / text / pause step.
                            HorizontalLayout {
                                spacing: 6px;
                                alignment: start;
                                Text {
                                    text: "add:";
                                    color: #cfd6df;
                                    font-size: 12px;
                                    font-family: "JetBrains Mono";
                                    vertical-alignment: center;
                                }
                                IconButton {
                                    wide: true;
                                    text: "key\u{2026}";
                                    clicked => {
                                        root.open_picker("macro_token");
                                    }
                                }
                                LineEdit {
                                    width: 130px;
                                    height: 28px;
                                    font-size: 13px;
                                    placeholder-text: "type text";
                                    text <=> root.macro_text_input;
                                    accepted(t) => {
                                        root.macro_add_text();
                                    }
                                }
                                IconButton {
                                    wide: true;
                                    text: "+ text";
                                    clicked => {
                                        root.macro_add_text();
                                    }
                                }
                                LineEdit {
                                    width: 64px;
                                    height: 28px;
                                    font-size: 13px;
                                    placeholder-text: "ms";
                                    text <=> root.macro_delay_input;
                                    accepted(t) => {
                                        root.macro_add_delay();
                                    }
                                }
                                IconButton {
                                    wide: true;
                                    text: "+ pause";
                                    clicked => {
                                        root.macro_add_delay();
                                    }
                                }
                            }
                            // add a chord step: modifier toggles + a key.
                            HorizontalLayout {
                                spacing: 6px;
                                alignment: start;
                                Text {
                                    text: "chord:";
                                    color: #cfd6df;
                                    font-size: 12px;
                                    font-family: "JetBrains Mono";
                                    vertical-alignment: center;
                                }
                                IconButton {
                                    wide: true;
                                    text: "Ctrl";
                                    active: root.macro_chord_c;
                                    clicked => {
                                        root.macro_chord_c = !root.macro_chord_c;
                                    }
                                }
                                IconButton {
                                    wide: true;
                                    text: "Meta";
                                    active: root.macro_chord_m;
                                    clicked => {
                                        root.macro_chord_m = !root.macro_chord_m;
                                    }
                                }
                                IconButton {
                                    wide: true;
                                    text: "Alt";
                                    active: root.macro_chord_a;
                                    clicked => {
                                        root.macro_chord_a = !root.macro_chord_a;
                                    }
                                }
                                IconButton {
                                    wide: true;
                                    text: "Shift";
                                    active: root.macro_chord_s;
                                    clicked => {
                                        root.macro_chord_s = !root.macro_chord_s;
                                    }
                                }
                                IconButton {
                                    wide: true;
                                    text: "AltGr";
                                    active: root.macro_chord_g;
                                    clicked => {
                                        root.macro_chord_g = !root.macro_chord_g;
                                    }
                                }
                                LineEdit {
                                    width: 80px;
                                    height: 28px;
                                    font-size: 13px;
                                    placeholder-text: "key";
                                    text <=> root.macro_chord_key;
                                }
                                IconButton {
                                    wide: true;
                                    text: "pick\u{2026}";
                                    clicked => {
                                        root.open_picker("macro_chord_key");
                                    }
                                }
                                IconButton {
                                    wide: true;
                                    text: "+ chord";
                                    clicked => {
                                        root.macro_add_chord();
                                    }
                                }
                            }
                            // repeat (macro2): hold the key to repeat the macro.
                            HorizontalLayout {
                                spacing: 6px;
                                alignment: start;
                                IconButton {
                                    wide: true;
                                    text: "repeat while held";
                                    active: root.macro_repeat_on;
                                    clicked => {
                                        root.macro_repeat_on = !root.macro_repeat_on;
                                    }
                                }
                                if root.macro_repeat_on: Text {
                                    text: "wait";
                                    color: #cfd6df;
                                    font-size: 12px;
                                    font-family: "JetBrains Mono";
                                    vertical-alignment: center;
                                }
                                if root.macro_repeat_on: LineEdit {
                                    width: 64px;
                                    height: 28px;
                                    font-size: 13px;
                                    placeholder-text: "ms";
                                    text <=> root.macro_repeat_timeout;
                                }
                                if root.macro_repeat_on: Text {
                                    text: "then every";
                                    color: #cfd6df;
                                    font-size: 12px;
                                    font-family: "JetBrains Mono";
                                    vertical-alignment: center;
                                }
                                if root.macro_repeat_on: LineEdit {
                                    width: 64px;
                                    height: 28px;
                                    font-size: 13px;
                                    placeholder-text: "ms";
                                    text <=> root.macro_repeat_count;
                                }
                            }
                            HorizontalLayout {
                                alignment: start;
                                IconButton {
                                    wide: true;
                                    text: "set macro";
                                    active: root.macro_rows.length > 0;
                                    clicked => {
                                        if (root.macro_rows.length > 0) {
                                            root.apply_macro();
                                        }
                                    }
                                }
                            }
                        }
                    }

                    // save: write the draft and show the copy-paste install steps;
                    // apply: the one-click pkexec path when this install supports it.
                    HorizontalLayout {
                        spacing: 8px;
                        alignment: start;
                        IconButton {
                            wide: true;
                            text: "save draft";
                            active: root.edit_dirty && !root.apply_in_flight;
                            clicked => {
                                root.save_draft();
                            }
                        }
                        if root.apply_available: IconButton {
                            wide: true;
                            text: "apply to /etc/keyd\u{2026}";
                            active: root.edit_dirty && root.apply_state == "idle";
                            clicked => {
                                if (root.apply_state == "idle") {
                                    root.start_apply();
                                }
                            }
                        }
                        // delete this whole config (destructive — confirm-gated).
                        // Only when one-click apply can reach it and nothing's in flight.
                        if root.apply_available && root.apply_state == "idle" && !root.delete_config_prompt: IconButton {
                            wide: true;
                            text: "delete config\u{2026}";
                            active: true;
                            clicked => {
                                root.delete_config_prompt = true;
                            }
                        }
                        if root.apply_hint != "": Text {
                            text: root.apply_hint;
                            color: #4a525e;
                            font-size: 11px;
                            vertical-alignment: center;
                        }
                    }
                    // delete-config confirm: destructive, so an explicit second step.
                    if root.delete_config_prompt: Rectangle {
                        height: dcbar.preferred-height + 12px;
                        border-radius: 8px;
                        background: #2a1d1d;
                        border-width: 1px;
                        border-color: #e5534b;
                        dcbar := HorizontalLayout {
                            padding-left: 10px;
                            padding-right: 10px;
                            spacing: 10px;
                            Text {
                                text: "\u{26a0} Delete this config from /etc/keyd? The keyboard returns to its default mapping. A timestamped backup is kept.";
                                color: #ff8b82;
                                font-size: 12px;
                                font-weight: 700;
                                vertical-alignment: center;
                                wrap: word-wrap;
                                horizontal-stretch: 1;
                            }
                            IconButton {
                                wide: true;
                                text: "cancel";
                                active: true;
                                clicked => {
                                    root.delete_config_prompt = false;
                                }
                            }
                            IconButton {
                                wide: true;
                                text: "delete";
                                clicked => {
                                    root.delete_config();
                                }
                            }
                        }
                    }
                    if root.draft_info != "": Rectangle {
                        background: #11151c;
                        border-color: #2a3340;
                        border-width: 1px;
                        border-radius: 8px;
                        height: dinfo.preferred-height + 16px;
                        // read-only TextInput (not Text) so the install steps are
                        // selectable / copy-pasteable straight from the panel.
                        dinfo := TextInput {
                            x: 8px;
                            y: 8px;
                            width: parent.width - 16px;
                            read-only: true;
                            wrap: word-wrap;
                            text: root.draft_info;
                            color: #cfd6df;
                            font-size: 12px;
                            font-family: "JetBrains Mono";
                        }
                    }

                    // ---- one-click apply flow (E2) ----
                    // confirm: the scan found command()/macro() — they run with root
                    // effect / inject keystrokes, so they need an unmistakable opt-in.
                    if root.apply_state == "confirm": Rectangle {
                        height: cbar.preferred-height + 12px;
                        border-radius: 8px;
                        background: #2a1d1d;
                        border-width: 1px;
                        border-color: #e5534b;
                        cbar := HorizontalLayout {
                            padding-left: 10px;
                            padding-right: 10px;
                            spacing: 10px;
                            Text {
                                text: "\u{26a0} This config can run a command or send keystrokes when you press a key \u{2014} and commands run as root (here, or in a file it includes). Apply anyway?";
                                color: #ff8b82;
                                font-size: 12px;
                                font-weight: 700;
                                vertical-alignment: center;
                                wrap: word-wrap;
                                horizontal-stretch: 1;
                            }
                            IconButton {
                                wide: true;
                                text: "cancel";
                                active: true;
                                clicked => {
                                    root.cancel_apply();
                                }
                            }
                            IconButton {
                                wide: true;
                                text: "apply anyway";
                                clicked => {
                                    root.confirm_apply();
                                }
                            }
                        }
                    }

                    // auth: pkexec's agent owns the password dialog; we just wait.
                    if root.apply_state == "auth": HorizontalLayout {
                        spacing: 10px;
                        alignment: start;
                        Text {
                            text: "waiting for authentication\u{2026}";
                            color: #f0b429;
                            font-size: 12px;
                            font-weight: 700;
                            vertical-alignment: center;
                        }
                        IconButton {
                            wide: true;
                            text: "cancel";
                            clicked => {
                                root.cancel_apply();
                            }
                        }
                    }

                    // countdown: the change is LIVE — but the controls (test field,
                    // timer, KEEP/revert) live in the always-on-top ApplyDialog so
                    // the user can type to verify. Here we just point at it.
                    if root.apply_state == "countdown": Text {
                        text: "\u{2192} change is live \u{2014} keep or revert it in the test window";
                        color: #3ddc84;
                        font-size: 12px;
                        font-weight: 700;
                    }

                    // terminal states: one bar, state-colored, dismissed explicitly.
                    if root.apply_state == "kept" || root.apply_state == "reverted"
                        || root.apply_state == "revert-failed" || root.apply_state == "failed": Rectangle {
                        height: tbar.preferred-height + 12px;
                        border-radius: 8px;
                        background: root.apply_state == "kept" ? #122117
                            : (root.apply_state == "reverted" ? #241d10 : #2a1d1d);
                        border-width: 1px;
                        border-color: root.apply_state == "kept" ? #3ddc84
                            : (root.apply_state == "reverted" ? #f0b429 : #e5534b);
                        tbar := HorizontalLayout {
                            padding-left: 10px;
                            padding-right: 10px;
                            spacing: 10px;
                            Text {
                                text: root.apply_state == "kept" ? "\u{2713} applied and kept"
                                    : (root.apply_state == "reverted" ? "\u{21a9} reverted \u{2014} your edits are still here"
                                    : (root.apply_state == "revert-failed" ? "\u{26a0} REVERT FAILED \u{2014} see details below" : "\u{26a0} apply did not run"));
                                color: root.apply_state == "kept" ? #3ddc84
                                    : (root.apply_state == "reverted" ? #f0b429 : #ff8b82);
                                font-size: 12px;
                                font-weight: 700;
                                vertical-alignment: center;
                                horizontal-stretch: 1;
                            }
                            IconButton {
                                wide: true;
                                text: "dismiss";
                                clicked => {
                                    root.cancel_apply();
                                }
                            }
                        }
                    }

                    // shared detail box for the apply flow: findings + staleness +
                    // diff while deciding/counting down, outcome detail afterwards.
                    // Selectable (read-only TextInput) — revert-failed instructions
                    // must be copy-pasteable.
                    if root.apply_state != "idle" && root.apply_info != "": Rectangle {
                        background: #11151c;
                        border-color: #2a3340;
                        border-width: 1px;
                        border-radius: 8px;
                        height: ainfo.preferred-height + 16px;
                        ainfo := TextInput {
                            x: 8px;
                            y: 8px;
                            width: parent.width - 16px;
                            read-only: true;
                            wrap: word-wrap;
                            text: root.apply_info;
                            color: #cfd6df;
                            font-size: 12px;
                            font-family: "JetBrains Mono";
                        }
                    }
                }

                // ---- searchable key picker overlay (E2) ----
                // Floats over the whole edit panel (a manually-positioned sibling of
                // editbody, so it paints on top of the VerticalLayout flow). The dim
                // backdrop's TouchArea is the click-outside-to-close; the card's own
                // TouchArea swallows clicks so picking inside never closes it.
                if root.picker_open: Rectangle {
                    x: 0;
                    y: 0;
                    width: parent.width;
                    height: parent.height;
                    background: #0a0d12ee;
                    TouchArea {
                        clicked => {
                            root.picker_open = false;
                            root.picker_query = "";
                        }
                    }
                    Rectangle {
                        x: 12px;
                        y: 12px;
                        width: parent.width - 24px;
                        height: parent.height - 24px;
                        background: #11151c;
                        border-radius: 10px;
                        border-width: 1px;
                        border-color: #2f5d63;
                        TouchArea {}   // swallow clicks inside the card (don't close)
                        VerticalLayout {
                            padding: 10px;
                            spacing: 8px;
                            HorizontalLayout {
                                spacing: 8px;
                                Text {
                                    text: "pick a key";
                                    color: #8a93a0;
                                    font-size: 12px;
                                    font-weight: 700;
                                    vertical-alignment: center;
                                }
                                Text {
                                    text: root.picker_target == "tap" ? "\u{2192} tap"
                                        : root.picker_target == "chord_key1" ? "\u{2192} chord key 1"
                                        : root.picker_target == "chord_key2" ? "\u{2192} chord key 2"
                                        : root.picker_target == "chord_action" ? "\u{2192} chord action"
                                        : "\u{2192} binding";
                                    color: #6fc3cf;
                                    font-size: 12px;
                                    font-family: "JetBrains Mono";
                                    vertical-alignment: center;
                                    horizontal-stretch: 1;
                                }
                                IconButton {
                                    text: "\u{2715}";
                                    clicked => {
                                        root.picker_open = false;
                                        root.picker_query = "";
                                    }
                                }
                            }
                            search := LineEdit {
                                height: 30px;
                                font-size: 13px;
                                placeholder-text: "search keys\u{2026}";
                                text <=> root.picker_query;
                                edited(t) => {
                                    root.filter_keys(t);
                                }
                                // focus the field the moment the overlay appears — `init`
                                // fires on the `if`-created element; `forward-focus` would not.
                                init => {
                                    self.focus();
                                }
                            }
                            // common one-click keys (only with no query) — fast path above
                            // the full scrollable list.
                            if root.picker_query == "": Text {
                                text: "common";
                                color: #5a6673;
                                font-size: 11px;
                            }
                            if root.picker_query == "": HorizontalLayout {
                                spacing: 6px;
                                alignment: start;
                                for act in root.palette: Rectangle {
                                    width: cpal.preferred-width + 14px;
                                    height: cpal.preferred-height + 7px;
                                    border-radius: 6px;
                                    background: cpalta.has-hover ? #1b2129 : #161b22;
                                    border-width: 1px;
                                    border-color: #2a3340;
                                    cpalta := TouchArea {
                                        clicked => {
                                            root.pick_key(act);
                                        }
                                    }
                                    cpal := Text {
                                        x: 7px;
                                        y: 3px;
                                        text: act;
                                        color: #cfd6df;
                                        font-size: 11px;
                                        font-family: "JetBrains Mono";
                                    }
                                }
                            }
                            ScrollView {
                                vertical-stretch: 1;
                                VerticalLayout {
                                    alignment: start;
                                    spacing: 1px;
                                    for name in root.picker_results: Rectangle {
                                        height: 26px;
                                        border-radius: 5px;
                                        background: rowta.has-hover ? #1b2129 : transparent;
                                        rowta := TouchArea {
                                            clicked => {
                                                root.pick_key(name);
                                            }
                                        }
                                        Text {
                                            x: 8px;
                                            height: 100%;
                                            text: name;
                                            color: #cfd6df;
                                            font-size: 12px;
                                            font-family: "JetBrains Mono";
                                            vertical-alignment: center;
                                        }
                                    }
                                }
                            }
                            Text {
                                text: root.picker_truncated > 0
                                    ? root.picker_source + " \u{00b7} +\{root.picker_truncated} more \u{2014} refine search"
                                    : root.picker_source;
                                color: #5a6673;
                                font-size: 11px;
                                vertical-alignment: center;
                            }
                        }
                    }
                }
            }

            // The active keyboard's one morphing board (swapped by the keyd listen stream
            // as layers change; frozen to the chosen section while editing). Hidden while
            // editing [global] — those daemon options belong to no key, so the board has
            // nothing to show or pick.
            if !(root.edit_mode && root.editing_global): BoardView {
                data: root.active_board;
                active_layer: root.active_layer;
                live: root.live_connected && !root.edit_mode;
                editing: root.edit_mode;
                selected_phys: root.selected_phys;
                // in chord mode a board click picks a chord member, not a binding target.
                chord_mode: root.edit_mode && root.board_mode == "chord";
                chord_k1: root.chord_key1;
                chord_k2: root.chord_key2;
                key_clicked(phys) => {
                    root.select_key(phys);
                }
                zoom <=> root.zoom;
            }
        }
    }
}
